<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QuickServe Pro — Admin Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Nunito+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{
  --g:#27AE60;--gd:#1E8449;--gl:#E9F7EF;
  --n:#1B2A3B;--n2:#243447;
  --bg:#F4F6F9;--bdr:#DDE3EB;
  --t1:#1B2A3B;--t2:#4A5568;--t3:#8A96A3;
  --wh:#FFFFFF;--red:#E74C3C;--redl:#FEF2F2;
  --amber:#E67E22;--ambl:#FFF8F0;
  --blue:#2980B9;--bluel:#EBF5FB;
  --fh:'Nunito',sans-serif;--fb:'Nunito Sans',sans-serif;
  --sh-sm:0 2px 10px rgba(0,0,0,.07);
  --sh-md:0 8px 28px rgba(0,0,0,.11);
  --sh-lg:0 20px 60px rgba(0,0,0,.16);
  --r:12px;--r-sm:8px;--r-lg:18px;--r-xl:24px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--fb);background:var(--bg);color:var(--t1);display:flex;min-height:100vh;-webkit-font-smoothing:antialiased}
a{text-decoration:none;color:inherit}
button{cursor:pointer;font-family:var(--fb);border:none;outline:none}

/* ── LOGIN ── */
.login-screen{
  position:fixed;inset:0;z-index:9999;
  background:linear-gradient(145deg,var(--n),var(--n2));
  display:flex;align-items:center;justify-content:center;padding:16px;
  transition:opacity .4s,transform .4s;
}
.login-box{
  background:var(--wh);border-radius:var(--r-xl);
  padding:40px 36px;max-width:400px;width:100%;
  box-shadow:var(--sh-lg);text-align:center;
}
.login-logo{
  width:56px;height:56px;background:var(--g);border-radius:16px;
  margin:0 auto 16px;display:flex;align-items:center;justify-content:center;
}
.login-title{font-family:var(--fh);font-size:1.375rem;font-weight:900;color:var(--n);margin-bottom:4px}
.login-sub{font-size:.82rem;color:var(--t3);margin-bottom:20px}
.lf{display:flex;flex-direction:column;gap:4px;margin-bottom:12px;text-align:left}
.lf label{font-size:.7rem;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.06em}
.lf input{padding:11px 13px;border:1.5px solid var(--bdr);border-radius:var(--r-sm);font-size:.9rem;color:var(--t1);width:100%;transition:border-color .2s}
.lf input:focus{outline:none;border-color:var(--g)}
.login-btn{
  width:100%;padding:12px;background:var(--n);color:var(--wh);
  border-radius:var(--r);font-family:var(--fh);font-size:.95rem;font-weight:800;
  margin-top:6px;transition:all .2s;
}
.login-btn:hover{background:var(--n2)}
.login-warn{background:var(--ambl);border:1.5px solid rgba(230,126,34,.25);border-radius:var(--r-sm);padding:9px 12px;font-size:.76rem;color:var(--amber);margin-bottom:14px;text-align:left}

/* ── SIDEBAR ── */
.sidebar{
  width:236px;background:var(--n);min-height:100vh;
  display:flex;flex-direction:column;flex-shrink:0;
  position:sticky;top:0;height:100vh;overflow-y:auto;
}
.sb-logo{
  display:flex;align-items:center;gap:10px;
  padding:18px 16px 16px;border-bottom:1px solid rgba(255,255,255,.07);margin-bottom:8px;
}
.sb-logo-icon{
  width:30px;height:30px;background:var(--g);border-radius:8px;
  display:flex;align-items:center;justify-content:center;flex-shrink:0;
}
.sb-logo-text{font-family:var(--fh);font-size:.9rem;font-weight:900;color:var(--wh);letter-spacing:-.02em}
.sb-logo-text em{color:var(--g);font-style:normal}

.sb-section{font-size:.6rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.3);padding:10px 16px 5px;display:block}
.sb-item{
  display:flex;align-items:center;gap:10px;
  padding:9px 16px;cursor:pointer;transition:all .18s;
  color:rgba(255,255,255,.6);font-size:.84rem;font-weight:600;
  border-left:3px solid transparent;
}
.sb-item:hover{background:rgba(255,255,255,.06);color:var(--wh)}
.sb-item.active{background:rgba(255,255,255,.1);color:var(--wh);border-left-color:var(--g)}
.sb-icon{font-size:.95rem;width:18px;flex-shrink:0;text-align:center}
.sb-badge{
  margin-left:auto;background:var(--red);color:var(--wh);
  padding:1px 7px;border-radius:100px;font-size:.65rem;font-weight:800;
}
.sb-badge.green{background:var(--g)}
.sb-foot{margin-top:auto;padding:14px 16px;border-top:1px solid rgba(255,255,255,.07)}
.sb-profile{display:flex;align-items:center;gap:10px}
.sb-av{width:30px;height:30px;border-radius:50%;background:var(--g);display:flex;align-items:center;justify-content:center;font-size:.875rem}
.sb-name{font-size:.78rem;font-weight:700;color:var(--wh)}
.sb-role{font-size:.65rem;color:rgba(255,255,255,.4)}

/* ── MAIN ── */
.main{flex:1;overflow-x:hidden;min-height:100vh;display:flex;flex-direction:column}
.topbar{
  background:var(--wh);border-bottom:1px solid var(--bdr);
  padding:12px 24px;display:flex;align-items:center;gap:12px;
  position:sticky;top:0;z-index:100;box-shadow:var(--sh-sm);
}
.topbar-title{font-family:var(--fh);font-size:1rem;font-weight:800;color:var(--n)}
.search-wrap{flex:1;max-width:360px;position:relative}
.search-wrap input{
  width:100%;padding:8px 12px 8px 32px;
  border:1.5px solid var(--bdr);border-radius:var(--r-sm);
  font-size:.84rem;color:var(--t1);background:var(--bg);
}
.search-wrap input:focus{outline:none;border-color:var(--g)}
.search-icon{position:absolute;left:10px;top:50%;transform:translateY(-50%);font-size:.8rem;color:var(--t3)}
.topbar-actions{display:flex;align-items:center;gap:8px;margin-left:auto}
.notif-btn{position:relative;cursor:pointer;padding:6px;background:var(--bg);border-radius:var(--r-sm);font-size:1rem}
.notif-dot{position:absolute;top:2px;right:2px;width:7px;height:7px;border-radius:50%;background:var(--red);border:2px solid var(--wh)}

.page{padding:20px 24px;display:none;flex:1}
.page.active{display:block}

/* ── STAT CARDS ── */
.stat-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:14px;margin-bottom:20px}
.sc{background:var(--wh);border-radius:var(--r);border:1.5px solid var(--bdr);padding:18px;transition:all .2s}
.sc:hover{box-shadow:var(--sh-sm);transform:translateY(-2px)}
.sc-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:12px}
.sc-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem}
.sc-icon.g{background:var(--gl)}.sc-icon.b{background:var(--bluel)}.sc-icon.r{background:var(--redl)}.sc-icon.a{background:var(--ambl)}
.sc-change{font-size:.7rem;font-weight:800;padding:2px 7px;border-radius:100px}
.up{background:var(--gl);color:var(--gd)}.dn{background:var(--redl);color:var(--red)}
.sc-val{font-family:var(--fh);font-size:1.75rem;font-weight:900;color:var(--n);line-height:1;margin-bottom:3px}
.sc-lbl{font-size:.76rem;color:var(--t3);font-weight:600}

/* ── TABLE ── */
.tbl-wrap{background:var(--wh);border-radius:var(--r);border:1.5px solid var(--bdr);overflow:hidden;margin-bottom:20px}
.tbl-head{display:flex;align-items:center;justify-content:space-between;padding:14px 18px;border-bottom:1px solid var(--bdr)}
.tbl-title{font-family:var(--fh);font-size:.9rem;font-weight:800;color:var(--n)}
table{width:100%;border-collapse:collapse}
thead th{padding:9px 18px;text-align:left;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--t3);background:var(--bg);border-bottom:1px solid var(--bdr)}
tbody tr{border-bottom:1px solid var(--bdr);transition:background .15s}
tbody tr:last-child{border-bottom:none}
tbody tr:hover{background:var(--bg)}
tbody td{padding:12px 18px;font-size:.82rem;color:var(--t1);vertical-align:middle}
.td-av{display:flex;align-items:center;gap:10px}
.t-av{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--gl),var(--g));display:flex;align-items:center;justify-content:center;font-size:.875rem;flex-shrink:0}
.t-name{font-weight:700;color:var(--n);font-size:.84rem}
.t-sub{font-size:.7rem;color:var(--t3)}

/* ── PILLS ── */
.pill{display:inline-flex;align-items:center;gap:3px;padding:2px 9px;border-radius:100px;font-size:.68rem;font-weight:800}
.pill-pending{background:var(--ambl);color:var(--amber)}
.pill-verified{background:var(--gl);color:var(--gd)}
.pill-rejected{background:var(--redl);color:var(--red)}
.pill-active{background:var(--gl);color:var(--gd)}
.pill-suspended{background:var(--ambl);color:var(--amber)}
.pill-done{background:var(--gl);color:var(--gd)}
.pill-progress{background:var(--bluel);color:var(--blue)}
.pill-disputed{background:var(--redl);color:var(--red)}
.pill-banned{background:var(--redl);color:var(--red)}

/* ── ACTION BUTTONS ── */
.act{display:inline-flex;align-items:center;gap:3px;padding:5px 10px;border-radius:var(--r-sm);font-size:.72rem;font-weight:700;transition:all .18s;cursor:pointer;margin-right:3px}
.act-approve{background:var(--gl);color:var(--gd)}
.act-approve:hover{background:var(--g);color:var(--wh)}
.act-reject{background:var(--redl);color:var(--red)}
.act-reject:hover{background:var(--red);color:var(--wh)}
.act-info{background:var(--ambl);color:var(--amber)}
.act-info:hover{background:var(--amber);color:var(--wh)}
.act-view{background:var(--bluel);color:var(--blue)}
.act-view:hover{background:var(--blue);color:var(--wh)}
.act-ban{background:var(--redl);color:var(--red)}
.act-ban:hover{background:var(--red);color:var(--wh)}

.btn-sm-g{background:var(--g);color:var(--wh);padding:7px 16px;border-radius:100px;font-family:var(--fh);font-size:.78rem;font-weight:800;transition:all .2s}
.btn-sm-g:hover{background:var(--gd)}
.btn-sm-n{background:var(--n);color:var(--wh);padding:7px 16px;border-radius:100px;font-family:var(--fh);font-size:.78rem;font-weight:800;transition:all .2s}
.btn-sm-n:hover{background:var(--n2)}
.btn-sm-o{background:transparent;border:1.5px solid var(--bdr);color:var(--t1);padding:6px 14px;border-radius:100px;font-size:.78rem;font-weight:700;transition:all .2s}
.btn-sm-o:hover{border-color:var(--n);color:var(--n)}
.btn-sm-r{background:var(--red);color:var(--wh);padding:7px 16px;border-radius:100px;font-family:var(--fh);font-size:.78rem;font-weight:800;transition:all .2s}
.btn-sm-r:hover{background:#C0392B}

/* ── MODAL OVERLAY ── */
.mback{
  display:none;position:fixed;inset:0;
  background:rgba(27,42,59,.75);z-index:2000;
  backdrop-filter:blur(6px);
  align-items:center;justify-content:center;padding:16px;
}
.mback.open{display:flex}
.mbox{
  background:var(--wh);border-radius:var(--r-xl);
  padding:32px;max-width:500px;width:100%;
  position:relative;max-height:90vh;overflow-y:auto;
  animation:min .3s ease both;
}
@keyframes min{from{opacity:0;transform:scale(.93) translateY(12px)}to{opacity:1;transform:none}}
.mc{position:absolute;top:14px;right:14px;width:28px;height:28px;border-radius:50%;background:var(--bg);font-size:.8rem;color:var(--t2);display:flex;align-items:center;justify-content:center;transition:all .18s}
.mc:hover{background:var(--redl);color:var(--red)}
.mt{font-family:var(--fh);font-size:1.2rem;font-weight:900;color:var(--n);margin-bottom:4px}
.ms{font-size:.82rem;color:var(--t3);margin-bottom:18px}
.mf{display:flex;flex-direction:column;gap:4px;margin-bottom:13px}
.mf label{font-size:.7rem;font-weight:700;color:var(--t2);text-transform:uppercase;letter-spacing:.06em}
.mf input,.mf select,.mf textarea{
  padding:10px 13px;border:1.5px solid var(--bdr);
  border-radius:var(--r-sm);font-size:.875rem;color:var(--t1);
  width:100%;transition:border-color .2s;background:var(--wh);
  font-family:var(--fb);
}
.mf input:focus,.mf select:focus,.mf textarea:focus{outline:none;border-color:var(--g);box-shadow:0 0 0 3px rgba(39,174,96,.1)}
.mf textarea{resize:vertical;min-height:100px;line-height:1.6}
.btn-msub{width:100%;padding:12px;background:var(--g);color:var(--wh);border-radius:var(--r);font-family:var(--fh);font-size:.92rem;font-weight:800;margin-top:6px;transition:all .2s}
.btn-msub:hover{background:var(--gd)}
.btn-msub.danger{background:var(--red)}
.btn-msub.danger:hover{background:#C0392B}
.btn-msub.navy{background:var(--n)}
.btn-msub.navy:hover{background:var(--n2)}

/* Requirement checkboxes */
.req-list{display:flex;flex-direction:column;gap:8px;margin-bottom:14px}
.req-item{display:flex;align-items:flex-start;gap:8px}
.req-item input[type=checkbox]{margin-top:2px;accent-color:var(--amber);flex-shrink:0}
.req-item label{font-size:.82rem;color:var(--t2);cursor:pointer;line-height:1.4}

/* SMS preview box */
.sms-preview{
  background:var(--n2);border-radius:var(--r);padding:14px 16px;
  margin-top:14px;
}
.sms-preview-label{font-size:.65rem;font-weight:700;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
.sms-phone-bubble{
  background:var(--g);color:var(--wh);
  border-radius:12px 12px 12px 2px;
  padding:10px 14px;font-size:.78rem;line-height:1.6;
  max-width:85%;display:inline-block;
}
.sms-phone-bubble.red{background:var(--red)}
.sms-phone-bubble.amber{background:var(--amber)}
.sms-meta{font-size:.65rem;color:rgba(255,255,255,.35);margin-top:6px}

/* Legal audit table */
.audit-row{background:var(--bg);border-radius:var(--r-sm);padding:10px 14px;margin-bottom:8px;display:flex;flex-direction:column;gap:4px}
.audit-row-head{display:flex;align-items:center;justify-content:space-between}
.audit-user{font-size:.82rem;font-weight:700;color:var(--n)}
.audit-date{font-size:.7rem;color:var(--t3)}
.audit-sig{font-size:.84rem;font-style:italic;color:var(--t2)}
.audit-meta{font-size:.7rem;color:var(--t3)}

/* Alert box */
.alert{border-radius:var(--r-sm);padding:10px 14px;font-size:.8rem;font-weight:600;display:flex;align-items:flex-start;gap:8px;margin-bottom:14px}
.alert-warn{background:var(--ambl);border:1.5px solid rgba(230,126,34,.25);color:var(--amber)}
.alert-danger{background:var(--redl);border:1.5px solid rgba(231,76,60,.25);color:var(--red)}
.alert-success{background:var(--gl);border:1.5px solid rgba(39,174,96,.25);color:var(--gd)}
.alert-info{background:var(--bluel);border:1.5px solid rgba(41,128,185,.2);color:var(--blue)}

/* Chart bars */
.chart-bars{display:flex;align-items:flex-end;gap:6px;height:120px;margin-top:12px}
.cbar-wrap{flex:1;display:flex;flex-direction:column;align-items:center;gap:4px}
.cbar{width:100%;border-radius:4px 4px 0 0;background:var(--bluel);transition:height .8s ease;min-height:4px}
.cbar.hi{background:var(--g)}
.cbar-lbl{font-size:.6rem;color:var(--t3);font-weight:700}
.cbar-val{font-size:.62rem;color:var(--n);font-weight:800}

/* Verify panel */
.vp{background:var(--wh);border-radius:var(--r-lg);border:1.5px solid var(--bdr);overflow:hidden;margin-bottom:16px}
.vp-head{display:flex;align-items:center;gap:12px;padding:16px 20px;background:var(--n);color:var(--wh)}
.vp-av{width:42px;height:42px;border-radius:50%;background:rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;font-size:1.25rem}
.vp-name{font-family:var(--fh);font-size:.95rem;font-weight:800}
.vp-role{font-size:.72rem;opacity:.65}
.vp-body{padding:16px 20px}
.check-item{display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:var(--r-sm);font-size:.8rem;margin-bottom:6px}
.ci-pass{background:var(--gl);color:var(--gd)}
.ci-fail{background:var(--redl);color:var(--red)}
.ci-pending{background:var(--ambl);color:var(--amber)}
.id-imgs{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px}
.id-img{border-radius:var(--r-sm);overflow:hidden;border:1.5px solid var(--bdr);aspect-ratio:16/9;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:1.75rem;position:relative}
.id-img-lbl{position:absolute;bottom:6px;left:6px;background:rgba(0,0,0,.6);color:var(--wh);padding:2px 7px;border-radius:4px;font-size:.62rem;font-weight:700}
.info-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-bottom:14px}
.info-cell{background:var(--bg);border-radius:var(--r-sm);padding:8px 10px}
.info-cell-lbl{font-size:.62rem;font-weight:700;color:var(--t3);text-transform:uppercase;letter-spacing:.05em}
.info-cell-val{font-size:.8rem;font-weight:700;color:var(--n);margin-top:2px}

/* Toast */
#toast{position:fixed;bottom:22px;left:50%;transform:translateX(-50%);background:var(--n);color:var(--wh);padding:10px 20px;border-radius:100px;font-size:.82rem;font-weight:600;box-shadow:var(--sh-lg);z-index:9999;transition:all .3s;opacity:0;pointer-events:none;white-space:nowrap;max-width:90vw;text-align:center}
#toast.show{opacity:1}

/* Mobile toggle */
.mob-toggle{display:none;position:fixed;bottom:18px;left:18px;z-index:700;background:var(--n);color:var(--wh);border:none;width:44px;height:44px;border-radius:50%;font-size:1.1rem;cursor:pointer;box-shadow:var(--sh-lg)}
@media(max-width:900px){.sidebar{position:fixed;left:-236px;z-index:600;transition:left .3s}.sidebar.open{left:0}.mob-toggle{display:flex;align-items:center;justify-content:center}.main{margin-left:0}}
@media(max-width:600px){.stat-grid{grid-template-columns:1fr 1fr}.info-grid{grid-template-columns:1fr 1fr}.page{padding:14px 16px}.topbar{padding:10px 16px}}
</style>
</head>
<body>

<!-- ══ LOGIN ════════════════════════════════════════════ -->
<div class="login-screen" id="loginScreen">
  <div class="login-box">
    <div class="login-logo">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <path d="M7 12C7 9.24 9.24 7 12 7C13.68 7 15.16 7.84 16.06 9.1" stroke="white" stroke-width="2" stroke-linecap="round"/>
        <path d="M15.4 7.8L16.2 10.4L13.6 11" stroke="white" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M9 12.5L11 14.5L15 10.5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <div class="login-title">Admin Dashboard</div>
    <div class="login-sub">QuickServe Pro · Authorised Access Only</div>
    <div class="login-warn">⚠️ Restricted to authorised administrators. Unauthorised access is a criminal offence under Ugandan law.</div>
    <div class="lf"><label>Admin Email</label><input type="email" id="liEmail" value="admin@quickservepro.ug" placeholder="admin@quickservepro.ug"></div>
    <div class="lf"><label>Password</label><input type="password" id="liPw" value="admin2025" placeholder="••••••••"></div>
    <button class="login-btn" onclick="doAdminLogin()">🔐 Sign In to Dashboard</button>
    <div style="margin-top:10px;font-size:.7rem;color:var(--t3)">Demo: credentials are pre-filled</div>
  </div>
</div>

<!-- ══ SIDEBAR ═══════════════════════════════════════════ -->
<aside class="sidebar" id="sidebar">
  <div class="sb-logo">
    <div class="sb-logo-icon">
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M4 8C4 5.79 5.79 4 8 4C9.34 4 10.52 4.65 11.24 5.66" stroke="white" stroke-width="1.5" stroke-linecap="round"/><path d="M10.8 4.5L11.3 6.3L9.5 6.7" stroke="white" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M5.5 8.5L7 10L10.5 6.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </div>
    <div class="sb-logo-text">Quick<em>Serve</em> Pro</div>
  </div>

  <span class="sb-section">Overview</span>
  <div class="sb-item active" onclick="showPage('dashboard')"><span class="sb-icon">📊</span> Dashboard</div>
  <div class="sb-item" onclick="showPage('analytics')"><span class="sb-icon">📈</span> Analytics</div>

  <span class="sb-section">People</span>
  <div class="sb-item" onclick="showPage('verification')">
    <span class="sb-icon">🪪</span> Verify Workers
