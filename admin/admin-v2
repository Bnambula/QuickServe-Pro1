  <div class="page" id="page-revenue"><div class="stat-grid"><div class="sc"><div class="sc-top"><div class="sc-icon g">💰</div><span class="sc-change up">↑ 19%</span></div><div class="sc-val">4.2M</div><div class="sc-lbl">Revenue This Month (UGX)</div></div><div class="sc"><div class="sc-top"><div class="sc-icon b">📊</div></div><div class="sc-val">38.7M</div><div class="sc-lbl">Year to Date (UGX)</div></div><div class="sc"><div class="sc-top"><div class="sc-icon a">💳</div></div><div class="sc-val">20%</div><div class="sc-lbl">Avg Commission</div></div></div></div>
  <div class="page" id="page-settings"><div style="display:grid;grid-template-columns:1fr 1fr;gap:16px"><div style="background:var(--wh);border-radius:var(--r);border:1.5px solid var(--bdr);padding:20px"><div style="font-family:var(--fh);font-size:.9rem;font-weight:800;color:var(--n);margin-bottom:16px">⚙️ Platform Settings</div><div style="display:flex;flex-direction:column;gap:12px"><div style="display:flex;align-items:center;justify-content:space-between;background:var(--bg);border-radius:var(--r-sm);padding:10px 14px"><div><div style="font-size:.84rem;font-weight:600;color:var(--n)">Commission Rate</div><div style="font-size:.72rem;color:var(--t3)">Per completed job</div></div><div style="display:flex;align-items:center;gap:4px"><input type="number" value="20" min="5" max="35" style="width:54px;border:1.5px solid var(--bdr);border-radius:var(--r-sm);padding:4px 6px;font-size:.84rem;text-align:center"> %</div></div><div style="display:flex;align-items:center;justify-content:space-between;background:var(--bg);border-radius:var(--r-sm);padding:10px 14px"><div><div style="font-size:.84rem;font-weight:600;color:var(--n)">Face Match Threshold</div></div><input type="number" value="85" min="70" max="99" style="width:60px;border:1.5px solid var(--bdr);border-radius:var(--r-sm);padding:4px 6px;font-size:.84rem;text-align:center"></div><button class="btn-sm-g" onclick="toast('✅ Settings saved!')">Save Settings</button></div></div></div></div>
</main>

<!-- ══ MODALS ══════════════════════════════════════════════ -->

<!-- ★ APPROVE MODAL with SMS preview -->
<div class="mback" id="m-approve">
  <div class="mbox">
    <button class="mc" onclick="closeM('approve')">✕</button>
    <div class="mt">✅ Approve Worker</div>
    <div class="ms" id="approve-sub">You are approving this worker. An automatic SMS will be sent to their registered phone.</div>
    <div class="alert alert-success" style="margin-bottom:14px">
      ✅ All automated checks passed. This worker is ready to be approved.
    </div>
    <div class="mf">
      <label>Optional Approval Note (internal)</label>
      <textarea placeholder="e.g. Documents clear. Manual review confirmed. Approved for Car Wash category."></textarea>
    </div>
    <div class="sms-preview">
      <div class="sms-preview-label">📱 Auto SMS — sent to worker immediately on approval</div>
      <div class="sms-phone-bubble" id="approveSmsText">
        ✅ Congratulations! Your QuickServe Pro worker account has been APPROVED. You can now start accepting jobs in your area. Download our app or login at quickservepro.ug to begin earning. Welcome to the team!
      </div>
      <div class="sms-meta">Sent via Africa's Talking SMS Gateway · +256 772 345 678</div>
    </div>
    <button class="btn-msub" style="margin-top:14px" onclick="submitApprove()">✅ Approve & Send SMS</button>
  </div>
</div>

<!-- ★ REJECT MODAL with popup reason textarea -->
<div class="mback" id="m-reject">
  <div class="mbox">
    <button class="mc" onclick="closeM('reject')">✕</button>
    <div class="mt">❌ Reject Application</div>
    <div class="ms" id="reject-sub">Provide a reason for rejection. This will be included in the automatic SMS and email sent to the applicant.</div>
    <div class="alert alert-danger">⚠️ This action will notify the applicant and record the rejection in the audit log.</div>
    <div class="mf">
      <label>Reason for Rejection <span style="color:var(--red)">*</span></label>
      <select id="rejectReason" onchange="updateRejectSMS()">
        <option value="">Select reason...</option>
        <option value="face_mismatch">Face does not match National ID photo</option>
        <option value="fake_id">National ID appears fraudulent or edited</option>
        <option value="blurry_id">ID documents are blurry or unreadable</option>
        <option value="duplicate_nin">Duplicate NIN — account already exists</option>
        <option value="expired_id">National ID is expired</option>
        <option value="incomplete">Incomplete documents submitted</option>
        <option value="policy">Does not meet platform requirements</option>
        <option value="other">Other (specify below)</option>
      </select>
    </div>
    <div class="mf">
      <label>Additional Details <span style="color:var(--red)">*</span></label>
      <textarea id="rejectDetails" placeholder="Explain clearly what the applicant needs to know..." oninput="updateRejectSMS()"></textarea>
    </div>
    <div class="mf">
      <label>Can they re-apply?</label>
      <select id="rejectReapply" onchange="updateRejectSMS()">
        <option value="yes">Yes — they can submit a new application</option>
        <option value="30days">Yes — but only after 30 days</option>
        <option value="no">No — permanently rejected</option>
      </select>
    </div>
    <div class="sms-preview">
      <div class="sms-preview-label">📱 Auto SMS — sent to applicant immediately</div>
      <div class="sms-phone-bubble red" id="rejectSmsText">
        ⚠️ Your QuickServe Pro application has not been approved at this time. Please check your email for full details and next steps.
      </div>
      <div class="sms-meta">Sent via Africa's Talking SMS Gateway</div>
    </div>
    <div style="display:flex;gap:10px;margin-top:14px">
      <button class="btn-sm-o" style="flex:1" onclick="closeM('reject')">Cancel</button>
      <button class="btn-msub danger" style="flex:2;margin:0" onclick="submitReject()">❌ Reject & Send SMS</button>
    </div>
  </div>
</div>

<!-- ★ MORE INFO MODAL with checkboxes + popup textarea -->
<div class="mback" id="m-moreinfo">
  <div class="mbox">
    <button class="mc" onclick="closeM('moreinfo')">✕</button>
    <div class="mt">📋 Request More Information</div>
    <div class="ms" id="moreinfo-sub">Select what is needed and add any custom message. An automatic SMS and email will be sent to the applicant.</div>

    <div class="mf" style="margin-bottom:8px"><label>What is required? (tick all that apply)</label></div>
    <div class="req-list" id="reqList">
      <div class="req-item"><input type="checkbox" id="r1" onchange="updateInfoSMS()"><label for="r1">🪪 Clearer photo of National ID (front)</label></div>
      <div class="req-item"><input type="checkbox" id="r2" onchange="updateInfoSMS()"><label for="r2">🪪 Clearer photo of National ID (back)</label></div>
      <div class="req-item"><input type="checkbox" id="r3" onchange="updateInfoSMS()"><label for="r3">🤳 New live selfie (better lighting required)</label></div>
      <div class="req-item"><input type="checkbox" id="r4" onchange="updateInfoSMS()"><label for="r4">📱 Phone number re-verification via OTP</label></div>
      <div class="req-item"><input type="checkbox" id="r5" onchange="updateInfoSMS()"><label for="r5">📍 Proof of address / location</label></div>
      <div class="req-item"><input type="checkbox" id="r6" onchange="updateInfoSMS()"><label for="r6">🏅 Certification or skills proof (for this service)</label></div>
      <div class="req-item"><input type="checkbox" id="r7" onchange="updateInfoSMS()"><label for="r7">📄 Additional identity document</label></div>
    </div>

    <div class="mf">
      <label>Custom Message to Applicant</label>
      <textarea id="infoMessage" placeholder="Add specific instructions or context for the applicant..." oninput="updateInfoSMS()"></textarea>
    </div>

    <div class="mf">
      <label>Deadline to Respond</label>
      <select id="infoDeadline" onchange="updateInfoSMS()">
        <option value="48hrs">48 hours</option>
        <option value="72hrs">72 hours</option>
        <option value="7days">7 days</option>
        <option value="14days">14 days</option>
      </select>
    </div>

    <div class="sms-preview">
      <div class="sms-preview-label">📱 Auto SMS — sent to applicant immediately</div>
      <div class="sms-phone-bubble amber" id="infoSmsText">
        📋 QuickServe Pro needs additional information to process your worker application. Please log in to your account and resubmit the required documents within 48 hours.
      </div>
      <div class="sms-meta">Sent via Africa's Talking SMS Gateway</div>
    </div>

    <div style="display:flex;gap:10px;margin-top:14px">
      <button class="btn-sm-o" style="flex:1" onclick="closeM('moreinfo')">Cancel</button>
      <button class="btn-msub navy" style="flex:2;margin:0" onclick="submitMoreInfo()">📋 Send Request & SMS</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div id="toast"></div>
<button class="mob-toggle" onclick="document.getElementById('sidebar').classList.toggle('open')">☰</button>

<script>
/* ═══════════════════════════════════════════════════
   ADMIN DASHBOARD — Complete Logic
═══════════════════════════════════════════════════ */

// ── Current action target ──
let actionTarget = { name: '', phone: '' };

// ── LOGIN ──
function doAdminLogin() {
  const email = document.getElementById('liEmail').value;
  const pw = document.getElementById('liPw').value;
  if (!email || !pw) { toast('❌ Enter credentials'); return; }
  const ls = document.getElementById('loginScreen');
  ls.style.opacity = '0'; ls.style.transform = 'scale(1.04)';
  setTimeout(() => { ls.style.display = 'none'; toast('✅ Logged in as Super Admin'); renderCharts(); }, 380);
}
document.getElementById('loginScreen').style.transition = 'opacity .38s,transform .38s';

function adminLogout() {
  document.getElementById('loginScreen').style.display = 'flex';
  document.getElementById('loginScreen').style.opacity = '1';
  document.getElementById('loginScreen').style.transform = 'none';
}

// ── PAGE NAVIGATION ──
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  document.querySelectorAll('.sb-item').forEach(s => s.classList.remove('active'));
  const titles = {
    dashboard:'📊 Dashboard', analytics:'📈 Analytics', verification:'🪪 Worker Verification',
    workers:'👷 All Workers', customers:'👥 Customers', 'legal-audit':'📋 Legal Audit Trail',
    jobs:'📝 All Jobs', disputes:'⚖️ Disputes', fraud:'🚨 Fraud Alerts',
    payments:'💳 Payments', revenue:'💰 Revenue', settings:'⚙️ Settings',
  };
  document.getElementById('pageTitle').textContent = titles[id] || id;
  if (id === 'analytics' || id === 'revenue') renderCharts();
}

// ── MODALS ──
function openM(id) {
  document.getElementById('m-' + id).classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeM(id) {
  document.getElementById('m-' + id).classList.remove('open');
  document.body.style.overflow = '';
}
document.querySelectorAll('.mback').forEach(el => {
  el.addEventListener('click', e => {
    if (e.target === el) { el.classList.remove('open'); document.body.style.overflow = ''; }
  });
});

// ── APPROVE ──
function openApproveModal(name, phone) {
  actionTarget = { name, phone };
  document.getElementById('approve-sub').textContent = `You are approving: ${name} (${phone})`;
  document.getElementById('approveSmsText').textContent =
    `✅ Congratulations ${name}! Your QuickServe Pro worker account has been APPROVED. You can now start accepting jobs in your area. Log in at quickservepro.ug to begin earning. Welcome to the team!`;
  openM('approve');
}

function submitApprove() {
  const name = actionTarget.name;
  const phone = actionTarget.phone;
  closeM('approve');
  toast(`✅ ${name} approved! SMS sent to ${phone}`);
  sendSMS('approved', name, phone);
  decrementBadge();
}

// ── REJECT ──
function openRejectModal(name, phone) {
  actionTarget = { name, phone };
  document.getElementById('reject-sub').textContent = `Rejecting: ${name} (${phone})`;
  document.getElementById('rejectReason').value = '';
  document.getElementById('rejectDetails').value = '';
  updateRejectSMS();
  openM('reject');
}

function updateRejectSMS() {
  const reason = document.getElementById('rejectReason');
  const details = document.getElementById('rejectDetails').value.trim();
  const reapply = document.getElementById('rejectReapply').value;
  const reapplyText = reapply === 'yes' ? 'You are welcome to submit a new application with the correct documents.'
    : reapply === '30days' ? 'You may re-apply after 30 days.'
    : 'This decision is final.';
  const reasonMap = {
    face_mismatch: 'Your selfie does not match your National ID photo.',
    fake_id: 'Your National ID could not be verified.',
    blurry_id: 'Your ID documents are unclear or unreadable.',
    duplicate_nin: 'A duplicate account was detected with this NIN.',
    expired_id: 'Your National ID has expired.',
    incomplete: 'Your application is missing required documents.',
    policy: 'Your application does not meet our platform requirements.',
    other: details || 'Please check your email for details.',
  };
  const reasonText = reasonMap[reason.value] || 'Please check your email for full details.';
  const extraText = details && reason.value !== 'other' ? ' ' + details : '';
  document.getElementById('rejectSmsText').textContent =
    `⚠️ QuickServe Pro: Your application has not been approved. Reason: ${reasonText}${extraText} ${reapplyText} Contact support for help.`;
}

function submitReject() {
  const reason = document.getElementById('rejectReason').value;
  const details = document.getElementById('rejectDetails').value.trim();
  if (!reason) { toast('❌ Please select a rejection reason'); return; }
  const name = actionTarget.name;
  const phone = actionTarget.phone;
  closeM('reject');
  toast(`❌ ${name} rejected. SMS + email sent to ${phone}`);
  sendSMS('rejected', name, phone);
  decrementBadge();
}

// ── MORE INFO ──
function openMoreInfoModal(name, phone) {
  actionTarget = { name, phone };
  document.getElementById('moreinfo-sub').textContent = `Requesting information from: ${name} (${phone})`;
  document.querySelectorAll('#reqList input[type=checkbox]').forEach(c => c.checked = false);
  document.getElementById('infoMessage').value = '';
  updateInfoSMS();
  openM('moreinfo');
}

function updateInfoSMS() {
  const checks = [];
  if (document.getElementById('r1').checked) checks.push('clearer National ID front photo');
  if (document.getElementById('r2').checked) checks.push('clearer National ID back photo');
  if (document.getElementById('r3').checked) checks.push('new live selfie in better lighting');
  if (document.getElementById('r4').checked) checks.push('phone number re-verification');
  if (document.getElementById('r5').checked) checks.push('proof of address');
  if (document.getElementById('r6').checked) checks.push('skills certification');
  if (document.getElementById('r7').checked) checks.push('additional identity document');
  const custom = document.getElementById('infoMessage').value.trim();
  const deadline = document.getElementById('infoDeadline').value;
  let smsText = `📋 QuickServe Pro needs additional information to process your worker application.`;
  if (checks.length > 0) smsText += ` Required: ${checks.join(', ')}.`;
  if (custom) smsText += ` Note: ${custom}`;
  smsText += ` Please log in and resubmit within ${deadline}.`;
  document.getElementById('infoSmsText').textContent = smsText;
}

function submitMoreInfo() {
  const checked = document.querySelectorAll('#reqList input[type=checkbox]:checked');
  const msg = document.getElementById('infoMessage').value.trim();
  if (checked.length === 0 && !msg) {
    toast('❌ Select at least one requirement or write a message'); return;
  }
  const name = actionTarget.name;
  const phone = actionTarget.phone;
  closeM('moreinfo');
  toast(`📋 Info request sent to ${name}. SMS + email delivered to ${phone}`);
  sendSMS('more_info', name, phone);
}

// ── APPROVE ALL ──
function approveAll() {
  toast('✅ All clean applications approved! SMS sent to 4 workers.');
  document.getElementById('pendingBadge').textContent = '3';
}

// ── SMS SIMULATOR ──
function sendSMS(type, name, phone) {
  const msgs = {
    approved: `[SMS → ${phone}] ✅ Congratulations ${name}! Your QuickServe Pro worker account is APPROVED. You can now accept jobs. Login at quickservepro.ug`,
    rejected: `[SMS → ${phone}] ⚠️ ${name}, your QuickServe Pro application was not approved. Check your email for details and next steps.`,
    more_info: `[SMS → ${phone}] 📋 ${name}, QuickServe Pro needs more information to process your application. Please log in and resubmit the required documents.`,
  };
  console.log('[SMS GATEWAY]', msgs[type]);
  // In production: POST to Africa's Talking API
  // fetch('/api/sms', { method:'POST', body: JSON.stringify({to: phone, message: msgs[type]}) })
}

function decrementBadge() {
  const b = document.getElementById('pendingBadge');
  const v = parseInt(b.textContent);
  if (v > 0) b.textContent = v - 1;
}

// ── CHARTS ──
function renderCharts() {
  const months = ['J','F','M','A','M','J','J','A','S','O','N','D'];
  const vals = [1.2,1.8,2.1,1.9,2.8,3.2,2.7,3.8,4.1,3.5,4.2,0];
  const max = Math.max(...vals);
  ['rChart'].forEach(id => {
    const el = document.getElementById(id);
    if (!el) return;
    el.innerHTML = vals.map((v,i) => `
      <div class="cbar-wrap">
        <div class="cbar-val">${v>0?v+'M':''}</div>
        <div class="cbar ${i===10?'hi':''}" style="height:${(v/max)*100}px"></div>
        <div class="cbar-lbl">${months[i]}</div>
      </div>`).join('');
  });
  const sEl = document.getElementById('sChart');
  if (sEl) {
    const svcs = [{n:'Cleaning',v:42},{n:'Laundry',v:28},{n:'Car Wash',v:18},{n:'Errands',v:12},{n:'MaidMatch',v:8}];
    const sm = Math.max(...svcs.map(s=>s.v));
    sEl.innerHTML = svcs.map(s=>`<div class="cbar-wrap"><div class="cbar-val">${s.v}%</div><div class="cbar hi" style="height:${(s.v/sm)*100}px"></div><div class="cbar-lbl">${s.n}</div></div>`).join('');
  }
}

// ── TOAST ──
let _tt;
function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(_tt); _tt = setTimeout(() => t.classList.remove('show'), 4000);
}
</script>
</body>
</html>
