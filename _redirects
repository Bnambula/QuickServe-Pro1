# Netlify Redirects — QuickServe Pro
# These rules handle URL routing for the static site

# Admin panel
/admin              /admin/index.html   200
/admin/*            /admin/index.html   200

# Worker registration
/register           /register.html      200
/join               /register.html      301
/worker             /register.html      301
/become-a-provider  /register.html      301

# Aliases
/home               /                   301
/booking            /                   301
/book               /                   301

# Catch-all (SPA fallback)
/*                  /index.html         200
